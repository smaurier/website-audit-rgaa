---
// Polices auto-hébergées (Fontsource) — pas de CDN Google Fonts (RGPD)
import '@fontsource/uncial-antiqua';        // wordmark « Nuada » uniquement
import '@fontsource/fraunces/600.css';      // titres
import '@fontsource/fraunces/700.css';
import '../styles/global.css';
import { ui, locales, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const t = ui[lang];
const l = t.layout;
const pageTitle = title ?? t.meta.title;
const pageDescription = description ?? t.meta.description;
const site = Astro.site ?? new URL('https://audit-rgaa.fr');
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    {Object.entries(locales).map(([code, { path }]) => (
      <link rel="alternate" hreflang={code} href={new URL(path, site).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={site.href} />
    <script is:inline>
      // Anti-flash : applique le thème choisi avant le premier rendu
      (function () {
        var t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{l.skip}</a>

    <header class="container" style="padding-block: 1rem; display:flex; align-items:center; justify-content:space-between; gap:1rem; flex-wrap:wrap;">
      <a href={locales[lang].path} class="brand" style="display:inline-flex; align-items:center; gap:0.6rem; text-decoration:none; color:var(--c-text);">
        <!-- La main d'argent de Nuada — décoratif, le texte adjacent porte le nom -->
        <svg aria-hidden="true" focusable="false" width="30" height="30" viewBox="0 0 32 32">
          <defs>
            <linearGradient id="silver" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#d9dde2" />
              <stop offset="0.55" stop-color="#98a2ac" />
              <stop offset="1" stop-color="#c4cad1" />
            </linearGradient>
          </defs>
          <g fill="url(#silver)">
            <rect x="9" y="6.5" width="3.2" height="10" rx="1.6" />
            <rect x="13.4" y="4" width="3.2" height="12" rx="1.6" />
            <rect x="17.8" y="5.5" width="3.2" height="10.5" rx="1.6" />
            <rect x="22.2" y="8" width="3.2" height="8.5" rx="1.6" />
            <rect x="3" y="15.5" width="9" height="3.6" rx="1.8" transform="rotate(32 7.5 17.3)" />
            <rect x="8.6" y="14.5" width="17" height="11.5" rx="5.5" />
          </g>
        </svg>
        Nuada
      </a>
      <nav aria-label={l.nav}>
        <ul style="list-style:none; display:flex; gap:1.25rem; margin:0; padding:0; flex-wrap:wrap;">
          <li><a href="#offre">{l.offer}</a></li>
          <li><a href="#methode">{l.method}</a></li>
          <li><a href="#contact">{l.contact}</a></li>
        </ul>
      </nav>
      <nav aria-label={l.langLabel}>
        <ul style="list-style:none; display:flex; gap:0.75rem; margin:0; padding:0;">
          {Object.entries(locales).map(([code, { label, path }]) => (
            <li>
              <a
                href={path}
                lang={code}
                hreflang={code}
                aria-current={code === lang ? 'true' : undefined}
                style={code === lang ? 'font-weight:700; text-decoration:none; color:var(--c-text);' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <!-- Le bouton de thème est injecté ici par JS (pas de contrôle mort sans JS) -->
      <span
        data-theme-mount
        data-label={l.theme.label}
        data-auto={l.theme.auto}
        data-light={l.theme.light}
        data-dark={l.theme.dark}
      ></span>
      <span id="theme-status" role="status" class="visually-hidden"></span>
    </header>

    <script>
      const mount = document.querySelector<HTMLElement>('[data-theme-mount]');
      if (mount) {
        const d = mount.dataset;
        const labels: Record<string, string | undefined> = { auto: d.auto, light: d.light, dark: d.dark };
        const order = ['auto', 'light', 'dark'];
        const status = document.getElementById('theme-status');

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'theme-toggle';
        const value = document.createElement('span');
        btn.append(`${d.label} : `, value);
        mount.replaceWith(btn);

        const current = () => document.documentElement.dataset.theme ?? 'auto';
        const render = () => { value.textContent = labels[current()] ?? ''; };

        btn.addEventListener('click', () => {
          const next = order[(order.indexOf(current()) + 1) % order.length];
          if (next === 'auto') {
            delete document.documentElement.dataset.theme;
            localStorage.removeItem('theme');
          } else {
            document.documentElement.dataset.theme = next;
            localStorage.setItem('theme', next);
          }
          render();
          if (status) status.textContent = `${d.label} : ${labels[next]}`;
        });

        render();
      }
    </script>

    <main id="main">
      <slot />
    </main>

    <footer class="container" style="padding-block: 2.5rem; margin-top:3rem; border-top:1px solid var(--c-border); color:var(--c-muted);">
      <p>© {new Date().getFullYear()} {l.footerRights}</p>
      <p set:html={l.footerProof} />
    </footer>
  </body>
</html>
