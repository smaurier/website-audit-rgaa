---
// Polices auto-hébergées (Fontsource) — pas de CDN Google Fonts (RGPD)
import '@fontsource/uncial-antiqua';        // wordmark « Nuada » uniquement
import '@fontsource/fraunces/600.css';      // titres
import '@fontsource/fraunces/700.css';
import '@fontsource/fraunces/900.css';      // h1
import '@fontsource/fraunces/900-italic.css'; // accents italiques du h1
import '../styles/global.css';
import { ui, locales, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const t = ui[lang];
const l = t.layout;
const pageTitle = title ?? t.meta.title;
const pageDescription = description ?? t.meta.description;
const site = Astro.site ?? new URL('https://nuada.dev');
const canonical = new URL(Astro.url.pathname, site).href;
const ogLocale = { fr: 'fr_FR', en: 'en_US', es: 'es_ES' }[lang];

// Données structurées — l'entité Nuada pour Google et les LLM (GEO)
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Nuada',
  description: t.meta.description,
  url: site.href,
  inLanguage: ['fr', 'en', 'es'],
  founder: { '@type': 'Person', name: 'Sylvain Maurier' },
  knowsAbout: [
    'Accessibilité numérique',
    'RGAA 4',
    'WCAG 2.2',
    'European Accessibility Act',
    'EN 301 549',
    'React',
    'React Native',
  ],
  areaServed: ['France', 'Europe', 'España', 'Latin America', 'United States'],
  makesOffer: [
    {
      '@type': 'Offer',
      name: t.offer.paliers[0].nom,
      price: '1200',
      priceCurrency: 'EUR',
      description: t.offer.paliers[0].scope,
    },
    {
      '@type': 'Offer',
      name: t.offer.paliers[1].nom,
      priceSpecification: {
        '@type': 'PriceSpecification',
        minPrice: '4900',
        priceCurrency: 'EUR',
      },
      description: t.offer.paliers[1].scope,
    },
    {
      '@type': 'Offer',
      name: t.offer.paliers[2].nom,
      description: t.offer.paliers[2].scope,
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Nuada" />
    <meta property="og:locale" content={ogLocale} />
    <meta name="twitter:card" content="summary" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    {Object.entries(locales).map(([code, { path }]) => (
      <link rel="alternate" hreflang={code} href={new URL(path, site).href} />
    ))}
    <link rel="alternate" hreflang="x-default" href={site.href} />
    <script is:inline>
      // Anti-flash : applique le thème choisi avant le premier rendu
      // + marqueur js pour les états initiaux des reveals (sans JS, rien n'est masqué)
      (function () {
        document.documentElement.classList.add('js');
        var t = localStorage.getItem('theme');
        if (t === 'light' || t === 'dark') document.documentElement.dataset.theme = t;
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{l.skip}</a>

    <header class="container site-header" role="banner">
      <a href={locales[lang].path} class="brand">
        <!-- La main d'argent de Nuada (4c « la frappe pleine ») — décoratif, le texte adjacent porte le nom -->
        <svg aria-hidden="true" focusable="false" width="28" height="28" viewBox="0 0 28 28">
          <defs>
            <linearGradient id="silver" gradientUnits="userSpaceOnUse" x1="0" y1="0" x2="28" y2="28">
              <stop offset="0" stop-color="#d9dde2" />
              <stop offset="0.5" stop-color="#8d97a1" />
              <stop offset="1" stop-color="#c4cad1" />
            </linearGradient>
          </defs>
          <path d="M5 17.5 a9 6.5 0 0 0 18 0 z" fill="url(#silver)" />
          <g fill="url(#silver)">
            <rect x="4.9" y="11.2" width="2.6" height="7.3" rx="1.3" />
            <rect x="8.7" y="7.2" width="2.6" height="11.3" rx="1.3" />
            <rect x="12.7" y="5.6" width="2.6" height="12.9" rx="1.3" />
            <rect x="16.7" y="7" width="2.6" height="11.5" rx="1.3" />
            <rect x="20.5" y="10.4" width="2.6" height="8.1" rx="1.3" />
          </g>
        </svg>
        Nuada
      </a>
      <nav role="navigation" aria-label={l.nav}>
        <ul class="nav-list">
          <li><a class="nav-link" href="#offre">{l.offer}</a></li>
          <li><a class="nav-link" href="#methode">{l.method}</a></li>
          <li><a class="nav-link" href="#contact">{l.contact}</a></li>
        </ul>
      </nav>
      <nav role="navigation" aria-label={l.langLabel}>
        <ul class="lang-pills">
          {Object.entries(locales).map(([code, { label, path }]) => (
            <li>
              <a
                href={path}
                lang={code}
                hreflang={code}
                aria-current={code === lang ? 'true' : undefined}
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
      <!-- Le bouton de thème est injecté ici par JS (pas de contrôle mort sans JS) -->
      <span
        data-theme-mount
        data-label={l.theme.label}
        data-auto={l.theme.auto}
        data-light={l.theme.light}
        data-dark={l.theme.dark}
      ></span>
      <span id="theme-status" role="status" class="visually-hidden"></span>
    </header>

    <script>
      const mount = document.querySelector<HTMLElement>('[data-theme-mount]');
      if (mount) {
        const d = mount.dataset;
        const labels: Record<string, string | undefined> = { auto: d.auto, light: d.light, dark: d.dark };
        const order = ['auto', 'light', 'dark'];
        const status = document.getElementById('theme-status');

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'theme-toggle';
        const value = document.createElement('span');
        btn.append(`${d.label} : `, value);
        mount.replaceWith(btn);

        const current = () => document.documentElement.dataset.theme ?? 'auto';
        const render = () => { value.textContent = labels[current()] ?? ''; };

        btn.addEventListener('click', () => {
          const next = order[(order.indexOf(current()) + 1) % order.length];
          const apply = () => {
            if (next === 'auto') {
              delete document.documentElement.dataset.theme;
              localStorage.removeItem('theme');
            } else {
              document.documentElement.dataset.theme = next;
              localStorage.setItem('theme', next);
            }
            render();
          };
          // Fondu de theme via View Transitions, si dispo et mouvement accepte
          if (document.startViewTransition && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.startViewTransition(apply);
          } else {
            apply();
          }
          if (status) status.textContent = `${d.label} : ${labels[next]}`;
        });

        render();
      }

      // Reveals au scroll — uniquement si le mouvement est accepte
      if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in-view');
                io.unobserve(e.target);
              }
            }
          },
          { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
        );
        document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
      }

      // Boutons magnétiques — pointeur fin uniquement, mouvement accepté uniquement.
      // Purement décoratif : n'affecte ni le clavier, ni la cible tactile.
      if (
        !matchMedia('(prefers-reduced-motion: reduce)').matches &&
        matchMedia('(pointer: fine)').matches
      ) {
        for (const b of document.querySelectorAll<HTMLElement>('.btn')) {
          b.addEventListener('pointermove', (e) => {
            const r = b.getBoundingClientRect();
            const x = (e.clientX - r.left - r.width / 2) / (r.width / 2);
            const y = (e.clientY - r.top - r.height / 2) / (r.height / 2);
            b.style.translate = `${(x * 5).toFixed(1)}px ${(y * 4).toFixed(1)}px`;
          });
          b.addEventListener('pointerleave', () => {
            b.style.translate = '';
          });
        }
      }
    </script>

    <!-- tabindex=-1 : garantit le déplacement effectif du focus via le lien d'évitement (RGAA 12.7) -->
    <main id="main" role="main" tabindex="-1">
      <slot />
    </main>

    <footer class="container site-footer" role="contentinfo">
      <p>© {new Date().getFullYear()} {l.footerRights}</p>
      <p set:html={l.footerProof} />
      <p><a href="/mentions-legales/" hreflang="fr">{l.legalLink}</a></p>
    </footer>
  </body>
</html>
