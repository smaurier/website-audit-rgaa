---
import Base from '../layouts/Base.astro';
import EmailLink from './EmailLink.astro';
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
---

<Base lang={lang}>
  <!-- HERO — composition centrée sous le torque d'argent -->
  <section class="container hero">
    <svg class="hero-torque" width="560" height="480" viewBox="0 0 460 460" aria-hidden="true" focusable="false">
      <defs>
        <linearGradient id="torque" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#e0e3e7" stop-opacity="0.55" />
          <stop offset="0.5" stop-color="#b6bec6" stop-opacity="0.55" />
          <stop offset="1" stop-color="#dcdfe3" stop-opacity="0.55" />
        </linearGradient>
      </defs>
      <circle class="torque-arc" cx="230" cy="230" r="200" fill="none" stroke="url(#torque)" stroke-width="11" pathLength="100" stroke-dasharray="88.9 11.1" stroke-dashoffset="-30.55" stroke-linecap="round" />
      <circle class="torque-end" cx="162" cy="418" r="11" fill="url(#torque)" />
      <circle class="torque-end" cx="298" cy="418" r="11" fill="url(#torque)" />
    </svg>

    <div class="hero-content">
      <p class="eyebrow">{t.hero.eyebrow}</p>
      <h1 set:html={t.hero.h1Html} />
      <div class="silver-line" aria-hidden="true"></div>
      <p class="hero-lead" set:html={t.hero.leadHtml} />
      <p class="hero-cta">
        <a class="btn btn--primary" href="#contact">{t.hero.ctaPrimary}</a>
        <a class="btn btn--ghost" href="#methode">{t.hero.ctaSecondary}</a>
      </p>
      <ul class="hero-pills" role="list">
        {t.hero.pills.map((p) => (
          <li class="pill" lang={p.lang}>{p.text}</li>
        ))}
      </ul>
      <p class="hero-story-link">
        <a href="#nuada">{t.hero.storyLink}</a>
      </p>
    </div>
  </section>

  <!-- CADRE LEGAL -->
  <section class="container" aria-labelledby="legal-title">
    <div class="card card--accent reveal">
      <h2 id="legal-title" set:html={t.legal.titleHtml} />
      <p set:html={t.legal.bodyHtml} />
    </div>
  </section>

  <!-- OFFRE -->
  <section class="container" id="offre" aria-labelledby="offre-title">
    <h2 id="offre-title">{t.offer.title}</h2>
    <p class="section-lead">{t.offer.subtitle}</p>
    <ul class="grid" role="list">
      {t.offer.paliers.map((p) => (
        <li class:list={['card', 'reveal', { 'card--featured': p.phare }]}>
          {p.phare && <p class="badge">{t.offer.badge}</p>}
          <h3 class="tier-name">{p.nom}</h3>
          <p class="tier-target">{p.cible}</p>
          <p class="tier-price">{p.prix}</p>
          <p class="tier-scope">{p.scope}</p>
          <ul class="tier-list">
            {p.contenu.map((c) => <li>{c}</li>)}
          </ul>
          <p class="tier-deliverable">→ {p.livrable}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- METHODE -->
  <section class="container" id="methode" aria-labelledby="methode-title">
    <h2 id="methode-title">{t.method.title}</h2>
    <ol class="grid" role="list">
      {t.method.steps.map((s) => (
        <li class="card step reveal">
          <h3>{s.t}</h3>
          <p set:html={s.dHtml} />
        </li>
      ))}
    </ol>
  </section>

  <!-- PREUVE — le positionnement montré : une PR de remédiation -->
  <section class="container" aria-labelledby="preuve-title">
    <h2 id="preuve-title">{t.proof.title}</h2>
    <div class="proof-grid">
      <div class="reveal">
        <p set:html={t.proof.p1Html} />
        <p set:html={t.proof.p2Html} />
      </div>
      <figure class="pr-window reveal" aria-label={t.proof.pr.figLabel}>
        <div class="pr-bar" aria-hidden="true"></div>
        <div class="pr-body">
          <div class="pr-head">
            <span class="pr-dots" aria-hidden="true">
              <span></span><span></span><span></span>
            </span>
            <span>{t.proof.pr.title}</span>
            <span class="pr-badge">{t.proof.pr.badge}</span>
          </div>
          <pre class="pr-code">{t.proof.pr.lines.map((line) => (
            <span class={line.k === 'ctx' ? undefined : line.k}>{line.t}</span>
          ))}</pre>
          <figcaption class="pr-foot">
            {t.proof.pr.checks.map((c) => <span>{c}</span>)}
            <span class="pr-ready">{t.proof.pr.ready}</span>
          </figcaption>
        </div>
      </figure>
    </div>
  </section>

  <!-- POURQUOI NUADA -->
  <section class="container" id="nuada" aria-labelledby="nuada-title">
    <div class="card card--accent reveal">
      <h2 id="nuada-title">{t.story.title}</h2>
      <p set:html={t.story.p1Html} />
      <p set:html={t.story.p2Html} />
    </div>
  </section>

  <!-- CONTACT -->
  <section class="container" id="contact" aria-labelledby="contact-title">
    <div class="card reveal">
      <h2 id="contact-title">{t.contact.title}</h2>
      <p>{t.contact.body}</p>

      <form
        name="contact"
        method="POST"
        action={t.contact.form.action}
        data-netlify="true"
        netlify-honeypot="bot-field"
        class="contact-form"
      >
        <input type="hidden" name="form-name" value="contact" />
        <input type="hidden" name="lang" value={lang} />
        <p hidden>
          <label>Ne pas remplir : <input name="bot-field" /></label>
        </p>

        <p class="field">
          <label for="f-name">
            {t.contact.form.name} <span class="req">({t.contact.form.required})</span>
          </label>
          <input class="input" id="f-name" name="name" type="text" required autocomplete="name" />
        </p>

        <p class="field">
          <label for="f-email">
            {t.contact.form.email} <span class="req">({t.contact.form.required})</span>
          </label>
          <input class="input" id="f-email" name="email" type="email" required autocomplete="email" />
        </p>

        <p class="field">
          <label for="f-url">{t.contact.form.url}</label>
          <input class="input" id="f-url" name="website" type="url" autocomplete="url" />
        </p>

        <p class="field">
          <label for="f-message">
            {t.contact.form.message} <span class="req">({t.contact.form.required})</span>
          </label>
          <textarea class="input" id="f-message" name="message" required rows="6"></textarea>
        </p>

        <p class="field">
          <button type="submit" class="btn btn--primary">{t.contact.form.submit}</button>
        </p>
      </form>

      <p class="contact-alt">
        {t.contact.form.or}&nbsp;<EmailLink user="sylvain.maurier" domain="gmail.com" subject={t.contact.subject} />
      </p>
    </div>
  </section>
</Base>
