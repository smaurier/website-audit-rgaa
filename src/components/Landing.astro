---
import Base from '../layouts/Base.astro';
import EmailLink from './EmailLink.astro';
import { ui, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
---

<Base lang={lang}>
  <!-- HERO — composition centrée sous le torque d'argent -->
  <section class="container hero">
    <svg class="hero-torque" width="560" height="480" viewBox="0 0 460 460" aria-hidden="true" focusable="false">
      <defs>
        <linearGradient id="torque" x1="0" y1="0" x2="1" y2="1">
          <stop offset="0" stop-color="#e0e3e7" stop-opacity="0.55" />
          <stop offset="0.5" stop-color="#b6bec6" stop-opacity="0.55" />
          <stop offset="1" stop-color="#dcdfe3" stop-opacity="0.55" />
        </linearGradient>
      </defs>
      <circle class="torque-arc" cx="230" cy="230" r="200" fill="none" stroke="url(#torque)" stroke-width="11" pathLength="100" stroke-dasharray="88.9 11.1" stroke-dashoffset="-30.55" stroke-linecap="round" />
      <circle class="torque-end" cx="162" cy="418" r="11" fill="url(#torque)" />
      <circle class="torque-end" cx="298" cy="418" r="11" fill="url(#torque)" />
    </svg>

    <div class="hero-content">
      <p style="color:var(--c-accent); font-weight:600; margin:0 0 1.25rem; letter-spacing:0.1em; text-transform:uppercase; font-size:0.85em;">
        {t.hero.eyebrow}
      </p>
      <h1 style="max-width:48rem; margin-inline:auto;" set:html={t.hero.h1Html} />
      <div class="silver-line" aria-hidden="true"></div>
      <p style="font-size:1.15em; color:var(--c-muted); max-width:38rem; margin-inline:auto;" set:html={t.hero.leadHtml} />
      <p style="display:flex; gap:1rem; flex-wrap:wrap; justify-content:center; margin-top:2.25rem;">
        <a class="btn btn--primary" href="#contact">{t.hero.ctaPrimary}</a>
        <a class="btn btn--ghost" href="#methode">{t.hero.ctaSecondary}</a>
      </p>
      <ul style="list-style:none; display:flex; gap:0.9rem; flex-wrap:wrap; justify-content:center; margin:2.75rem 0 0; padding:0;">
        {t.hero.pills.map((p) => (
          <li class="pill" lang={p.lang}>{p.text}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- CADRE LEGAL -->
  <section class="container" aria-labelledby="legal-title">
    <div class="card reveal" style="border-left:4px solid var(--c-accent);">
      <h2 id="legal-title" style="margin-top:0;" set:html={t.legal.titleHtml} />
      <p style="margin-bottom:0;" set:html={t.legal.bodyHtml} />
    </div>
  </section>

  <!-- OFFRE -->
  <section class="container" id="offre" aria-labelledby="offre-title">
    <h2 id="offre-title">{t.offer.title}</h2>
    <p style="color:var(--c-muted);">{t.offer.subtitle}</p>
    <ul class="grid" style="list-style:none; padding:0; margin-top:1.5rem;">
      {t.offer.paliers.map((p, i) => (
        <li class="card reveal" style={`${p.phare ? 'border:2px solid var(--c-primary);' : ''}--reveal-delay:${i * 90}ms;`}>
          {p.phare && (
            <p style="margin:0 0 0.5rem; color:var(--c-primary); font-weight:700; font-size:0.85em; text-transform:uppercase; letter-spacing:0.04em;">
              {t.offer.badge}
            </p>
          )}
          <h3>{p.nom}</h3>
          <p style="color:var(--c-muted); margin:0 0 0.5rem;">{p.cible}</p>
          <p style="font-size:1.5em; font-weight:700; margin:0;">{p.prix}</p>
          <p style="color:var(--c-muted); font-size:0.9em; margin:0.25rem 0 1rem;">{p.scope}</p>
          <ul style="padding-left:1.1rem; margin:0 0 1rem;">
            {p.contenu.map((c) => <li>{c}</li>)}
          </ul>
          <p style="margin:0; font-weight:600;">→ {p.livrable}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- METHODE -->
  <section class="container" id="methode" aria-labelledby="methode-title">
    <h2 id="methode-title">{t.method.title}</h2>
    <ol class="grid" style="padding:0; margin-top:1.5rem;">
      {t.method.steps.map((s, i) => (
        <li class="card reveal" style={`--reveal-delay:${i * 90}ms;`}>
          <h3>{s.t}</h3>
          <p style="margin:0;" set:html={s.dHtml} />
        </li>
      ))}
    </ol>
  </section>

  <!-- PREUVE — le positionnement montré : une PR de remédiation -->
  <section class="container" aria-labelledby="preuve-title">
    <h2 id="preuve-title">{t.proof.title}</h2>
    <div style="display:grid; gap:var(--gap); grid-template-columns:repeat(auto-fit, minmax(min(100%, 20rem), 1fr)); align-items:center; margin-top:1.5rem;">
      <div class="reveal">
        <p style="margin-top:0;" set:html={t.proof.p1Html} />
        <p set:html={t.proof.p2Html} />
      </div>
      <figure class="pr-window reveal" style="--reveal-delay:140ms;" aria-label={t.proof.pr.figLabel}>
        <div class="pr-bar" aria-hidden="true"></div>
        <div class="pr-body">
          <div class="pr-head">
            <span style="display:flex; gap:6px;" aria-hidden="true">
              <span style="width:10px; height:10px; border-radius:50%; background:#3d5247;"></span>
              <span style="width:10px; height:10px; border-radius:50%; background:#3d5247;"></span>
              <span style="width:10px; height:10px; border-radius:50%; background:#3d5247;"></span>
            </span>
            <span>{t.proof.pr.title}</span>
            <span class="pr-badge">{t.proof.pr.badge}</span>
          </div>
          <pre class="pr-code">{t.proof.pr.lines.map((line) => (
            <span class={line.k === 'ctx' ? undefined : line.k} style="display:block; min-height:1.2em;">{line.t}</span>
          ))}</pre>
          <figcaption class="pr-foot">
            {t.proof.pr.checks.map((c) => <span>{c}</span>)}
            <span class="pr-ready">{t.proof.pr.ready}</span>
          </figcaption>
        </div>
      </figure>
    </div>
  </section>

  <!-- POURQUOI NUADA -->
  <section class="container" id="nuada" aria-labelledby="nuada-title">
    <div class="card reveal" style="border-left:4px solid var(--c-accent); background:var(--c-surface);">
      <h2 id="nuada-title" style="margin-top:0;">{t.story.title}</h2>
      <p set:html={t.story.p1Html} />
      <p style="margin-bottom:0;" set:html={t.story.p2Html} />
    </div>
  </section>

  <!-- CONTACT -->
  <section class="container" id="contact" aria-labelledby="contact-title">
    <div class="card reveal">
      <h2 id="contact-title" style="margin-top:0;">{t.contact.title}</h2>
      <p>{t.contact.body}</p>

      <form
        name="contact"
        method="POST"
        action={t.contact.form.action}
        data-netlify="true"
        netlify-honeypot="bot-field"
        style="display:grid; gap:1rem; max-width:36rem;"
      >
        <input type="hidden" name="form-name" value="contact" />
        <input type="hidden" name="lang" value={lang} />
        <p hidden>
          <label>Ne pas remplir : <input name="bot-field" /></label>
        </p>

        <p style="margin:0;">
          <label for="f-name" style="display:block; font-weight:600;">
            {t.contact.form.name} <span style="color:var(--c-accent);">({t.contact.form.required})</span>
          </label>
          <input id="f-name" name="name" type="text" required autocomplete="name"
            style="width:100%; padding:0.6rem; border:1px solid var(--c-border); border-radius:6px; background:var(--c-bg); color:var(--c-text);" />
        </p>

        <p style="margin:0;">
          <label for="f-email" style="display:block; font-weight:600;">
            {t.contact.form.email} <span style="color:var(--c-accent);">({t.contact.form.required})</span>
          </label>
          <input id="f-email" name="email" type="email" required autocomplete="email"
            style="width:100%; padding:0.6rem; border:1px solid var(--c-border); border-radius:6px; background:var(--c-bg); color:var(--c-text);" />
        </p>

        <p style="margin:0;">
          <label for="f-url" style="display:block; font-weight:600;">{t.contact.form.url}</label>
          <input id="f-url" name="website" type="url" autocomplete="url"
            style="width:100%; padding:0.6rem; border:1px solid var(--c-border); border-radius:6px; background:var(--c-bg); color:var(--c-text);" />
        </p>

        <p style="margin:0;">
          <label for="f-message" style="display:block; font-weight:600;">
            {t.contact.form.message} <span style="color:var(--c-accent);">({t.contact.form.required})</span>
          </label>
          <textarea id="f-message" name="message" required rows="6"
            style="width:100%; padding:0.6rem; border:1px solid var(--c-border); border-radius:6px; background:var(--c-bg); color:var(--c-text); font:inherit;"></textarea>
        </p>

        <p style="margin:0;">
          <button type="submit" class="btn btn--primary" style="border:none; cursor:pointer; font:inherit;">
            {t.contact.form.submit}
          </button>
        </p>
      </form>

      <p style="margin-top:1.5rem;">
        {t.contact.form.or}&nbsp;<EmailLink user="sylvain.maurier" domain="gmail.com" subject={t.contact.subject} />
      </p>
    </div>
  </section>
</Base>
