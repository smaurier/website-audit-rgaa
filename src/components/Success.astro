---
import Base from '../layouts/Base.astro';
import { ui, locales, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];
---

<Base lang={lang} title={t.success.title} description={t.success.body}>
  <section class="container success">
    <h1>{t.success.title}</h1>
    <p class="success-lead">{t.success.body}</p>
    <p class="success-back">
      <a class="btn btn--primary" href={locales[lang].path}>{t.success.back}</a>
    </p>
  </section>
</Base>
