---
import Base from '../layouts/Base.astro';
import EmailLink from '../components/EmailLink.astro';

const title = "Audit RGAA — l'auditeur qui code la solution";
const description =
  "Audits d'accessibilité RGAA / WCAG 2.2 par un dev fullstack. Pas un PDF de 80 pages : un audit + les PR de remédiation livrées. Conformité European Accessibility Act 2025.";

// Offre — BROUILLON à valider (cf. hub : offre à prix fixe = audit + PR de remédiation)
const paliers = [
  {
    nom: 'Diagnostic',
    cible: 'Site vitrine / landing',
    contenu: [
      "Audit des pages clés (parcours principal)",
      "Rapport priorisé par impact utilisateur",
      "Restitution visio 45 min",
    ],
    livrable: 'Rapport actionnable',
  },
  {
    nom: 'Audit + Remédiation',
    cible: 'Application / e-commerce',
    contenu: [
      "Audit RGAA complet sur périmètre défini",
      "Pull requests de correction livrées (React / RN)",
      "Vérification post-correction",
    ],
    livrable: 'Audit + code corrigé',
    phare: true,
  },
  {
    nom: 'Mise en conformité EAA',
    cible: 'Grand compte / obligation légale',
    contenu: [
      "Audit multi-parcours + déclaration d'accessibilité",
      "Accompagnement équipes dev (revue, pairing)",
      "Suivi de conformité dans le temps",
    ],
    livrable: 'Conformité EAA documentée',
  },
];
---

<Base title={title} description={description} lang="fr">
  <!-- HERO -->
  <section class="container" style="padding-block: clamp(2rem, 6vw, 4.5rem);">
    <p style="color:var(--c-accent); font-weight:600; margin:0 0 0.5rem; letter-spacing:0.02em;">
      Accessibilité numérique · RGAA · WCAG 2.2
    </p>
    <h1>L'auditeur qui <span style="color:var(--c-primary);">code la solution</span>.</h1>
    <p style="font-size:1.15em; color:var(--c-muted);">
      La plupart des audits livrent un PDF de 80 pages que personne ne sait appliquer.
      Moi je suis développeur fullstack : je livre l'audit <strong>et les <span lang="en">pull requests</span> de
      correction</strong>. Je parle aux équipes dev et j'arbitre conformité vs UX réelle.
    </p>
    <p style="display:flex; gap:0.75rem; flex-wrap:wrap; margin-top:1.5rem;">
      <a class="btn btn--primary" href="#contact">Demander un audit</a>
      <a class="btn btn--ghost" href="#methode">Voir la méthode</a>
    </p>
  </section>

  <!-- URGENCE EAA -->
  <section class="container" aria-labelledby="eaa-title">
    <div class="card" style="border-left:4px solid var(--c-accent);">
      <h2 id="eaa-title" style="margin-top:0;"><span lang="en">European Accessibility Act</span> : applicable depuis juin 2025</h2>
      <p style="margin-bottom:0;">
        L'EAA impose l'accessibilité à un large périmètre de services numériques (e-commerce,
        banque, transport, etc.). En France, le RGAA — déclinaison de WCAG — en est le cadre
        de référence. La non-conformité expose à des sanctions et ferme des marchés publics.
        <strong>Un audit maintenant, c'est de la conformité, pas du rattrapage.</strong>
      </p>
    </div>
  </section>

  <!-- OFFRE -->
  <section class="container" id="offre" aria-labelledby="offre-title">
    <h2 id="offre-title">Trois façons de travailler ensemble</h2>
    <p style="color:var(--c-muted);">Offre à prix fixe. Pas de temps facturé à l'aveugle : un périmètre, un livrable.</p>
    <ul class="grid" style="list-style:none; padding:0; margin-top:1.5rem;">
      {paliers.map((p) => (
        <li class="card" style={p.phare ? 'border:2px solid var(--c-primary);' : ''}>
          {p.phare && (
            <p style="margin:0 0 0.5rem; color:var(--c-primary); font-weight:700; font-size:0.85em; text-transform:uppercase; letter-spacing:0.04em;">
              Le plus demandé
            </p>
          )}
          <h3>{p.nom}</h3>
          <p style="color:var(--c-muted); margin:0 0 0.75rem;">{p.cible}</p>
          <ul style="padding-left:1.1rem; margin:0 0 1rem;">
            {p.contenu.map((c) => <li>{c}</li>)}
          </ul>
          <p style="margin:0; font-weight:600;">→ {p.livrable}</p>
        </li>
      ))}
    </ul>
  </section>

  <!-- METHODE -->
  <section class="container" id="methode" aria-labelledby="methode-title">
    <h2 id="methode-title">La méthode : du diagnostic au code</h2>
    <ol class="grid" style="padding:0; margin-top:1.5rem;">
      <li class="card"><h3>1. Cadrage</h3><p style="margin:0;">On définit le périmètre (parcours critiques) et le référentiel applicable (RGAA, WCAG 2.2, EAA).</p></li>
      <li class="card"><h3>2. Audit</h3><p style="margin:0;">Tests automatisés + manuels : clavier, lecteur d'écran, contrastes, structure. Priorisation par impact réel.</p></li>
      <li class="card"><h3>3. Remédiation</h3><p style="margin:0;">Je livre les correctifs sous forme de <span lang="en">pull requests</span> dans votre code, pas de recommandations abstraites.</p></li>
      <li class="card"><h3>4. Vérification</h3><p style="margin:0;">Contrôle post-correction et, si besoin, déclaration d'accessibilité conforme.</p></li>
    </ol>
  </section>

  <!-- PREUVE -->
  <section class="container" aria-labelledby="preuve-title">
    <h2 id="preuve-title">Une double compétence, un travail garanti</h2>
    <p>
      Développeur fullstack <em>et</em> spécialiste de l'accessibilité : je ne me contente pas de pointer
      les problèmes, je livre les corrections. Faire appel à moi, c'est la certitude d'un travail rigoureux,
      mené de bout en bout — de l'audit jusqu'au code en production.
    </p>
    <p>
      Ce site en est la garantie silencieuse : entièrement accessible, il applique au quotidien
      ce que je livre à mes clients.
    </p>
  </section>

  <!-- CONTACT -->
  <section class="container" id="contact" aria-labelledby="contact-title">
    <div class="card">
      <h2 id="contact-title" style="margin-top:0;">Parlons de votre projet</h2>
      <p>Décrivez votre site ou application et le cadre légal visé. Réponse sous 48 h.</p>
      <p style="font-size:1.15em;">
        Écrivez-moi&nbsp;: <EmailLink user="sylvain.maurier" domain="gmail.com" subject="Demande d'audit RGAA" />
      </p>
    </div>
  </section>
</Base>
