---
import Base from '../layouts/Base.astro';
---

<Base
  lang="fr"
  title="Page introuvable (erreur 404) — Nuada"
  description="La page demandée n'existe pas ou plus."
>
  <section class="container success">
    <p class="eyebrow">Erreur 404</p>
    <h1>Page introuvable</h1>
    <p class="success-lead">
      La page que vous cherchez n'existe pas ou n'existe plus. La navigation en haut de page
      reste à votre disposition, ou repartez de l'accueil.
    </p>
    <p class="success-back">
      <a class="btn btn--primary" href="/">Retour à l'accueil</a>
    </p>
  </section>
</Base>
